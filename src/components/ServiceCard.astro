---
import type { CollectionEntry } from "astro:content";

interface Props {
  service: CollectionEntry<"services">;
}

const { service } = Astro.props;
const { title, summary, features, ctaLabel, ctaHref, featured, priceFrom, currency } = service.data;

const ctaClass = featured
  ? "bg-[#1E3A8A] text-white"
  : "bg-[#F6F2EB] text-[#1C1917]";
---

<article class="rounded-md border border-[#E7E5E4] bg-white p-7">
  <h2 class="text-[38px] font-semibold leading-none text-[#1C1917]">{title}</h2>

  {priceFrom !== undefined && (
    <p class="mt-2 text-sm font-semibold uppercase tracking-[0.08em] text-[#78716C]">
      desde {priceFrom.toLocaleString("es-CO")} {currency ?? ""}
    </p>
  )}

  <p class="mt-4 text-base leading-7 text-[#78716C]">{summary}</p>

  <ul class="mt-6 space-y-2 text-sm text-[#78716C]">
    {features.map(f => <li>• {f}</li>)}
  </ul>

  <a
    href={ctaHref}
    class={`mt-8 inline-block rounded-sm px-5 py-3 text-sm font-semibold ${ctaClass}`}
  >
    {ctaLabel}
  </a>
</article>