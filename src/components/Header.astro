---
interface Props {
    activeNav?: "home" | "portafolio" | "services" | "contact";
}

const { activeNav = "home", } = Astro.props;

const navClass = (key: Props["activeNav"]) =>
	`border-b pb-1 text-sm font-medium transition ${
		activeNav === key ? "border-[#1E3A8A] text-[#1E3A8A]" : "border-transparent text-[#78716C] hover:text-[#1E3A8A]"
	}`;
---

<header class="border-b border-[#E7E5E4] bg-[#FAF7F2]">
    <div class="mx-auto flex w-full max-w-6xl items-center justify-between px-6 py-4">
        <a href="/" class="text-[17px] font-semibold text-[#1C1917]" aria-label="DevPortfolio home">LUFEP</a>
        <nav class="hidden items-center gap-5 md:flex" aria-label="Primary navigation">
            <a href="/" class={navClass("home")} aria-current={activeNav === "home" ? "page" : undefined}>Home</a>
            <a href="/portafolio" class={navClass("portafolio")} aria-current={activeNav === "portafolio" ? "page" : undefined}>Portafolio</a>
            <a href="/services" class={navClass("services")} aria-current={activeNav === "services" ? "page" : undefined}>Services</a>
            <a href="/contact" class={navClass("contact")} aria-current={activeNav === "contact" ? "page" : undefined}>Contact</a>
        </nav>
        <div class="flex items-center gap-3">
            <a
                href="/contact"
                class="hidden rounded-sm bg-[#1E3A8A] px-5 py-2 text-sm font-semibold text-white transition hover:bg-[#1B337A] md:inline-flex"
            >
                Get a Quote
            </a>
            <details class="group relative md:hidden" data-mobile-menu>
                <summary
                    class="flex h-9 w-9 cursor-pointer list-none items-center justify-center rounded-sm border border-[#E7E5E4] bg-white text-[#1C1917]"
                    aria-label="Open navigation menu"
                    aria-expanded="false"
                    aria-controls="mobile-navigation"
                    data-mobile-menu-toggle
                >
                    <svg class="h-5 w-5 group-open:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4 7h16M4 12h16M4 17h16" />
                    </svg>
                    <svg class="hidden h-5 w-5 group-open:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 6l12 12M18 6 6 18" />
                    </svg>
                </summary>
                <div id="mobile-navigation" class="absolute right-0 z-50 mt-3 w-56 rounded-md border border-[#E7E5E4] bg-white p-2 shadow-lg">
                    <nav class="space-y-1 text-sm" aria-label="Mobile navigation">
                        <a href="/" class="block rounded-sm px-3 py-2 text-[#1C1917] hover:bg-[#F6F2EB]">Home</a>
                        <a href="/portafolio" class="block rounded-sm px-3 py-2 text-[#1C1917] hover:bg-[#F6F2EB]">Portafolio</a>
                        <a href="/services" class="block rounded-sm px-3 py-2 text-[#1C1917] hover:bg-[#F6F2EB]">Services</a>
                        <a href="/contact" class="block rounded-sm px-3 py-2 text-[#1C1917] hover:bg-[#F6F2EB]">Contact</a>
                        <a href="/contact" class="mt-2 block rounded-sm bg-[#1E3A8A] px-3 py-2 text-center font-semibold text-white">Get a Quote</a>
                    </nav>
                </div>
            </details>
        </div>
    </div>
    <script is:inline>
        const mobileMenu = document.querySelector("[data-mobile-menu]");

        if (mobileMenu) {
            const mobileMenuToggle = mobileMenu.querySelector("[data-mobile-menu-toggle]");
            const updateExpandedState = () => {
                mobileMenuToggle?.setAttribute("aria-expanded", mobileMenu.open ? "true" : "false");
            };

            updateExpandedState();
            mobileMenu.addEventListener("toggle", updateExpandedState);

            mobileMenu.querySelectorAll("a").forEach((link) => {
                link.addEventListener("click", () => {
                    mobileMenu.removeAttribute("open");
                });
            });

            document.addEventListener("click", (event) => {
                if (event.target instanceof Node && !mobileMenu.contains(event.target)) {
                    mobileMenu.removeAttribute("open");
                }
            });
        }
    </script>
</header>