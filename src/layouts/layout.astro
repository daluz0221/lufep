---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { organizationSchema } from "../lib/structuredData";
import "../styles/global.css";

type JsonLd = Record<string, unknown>;

interface Props {
	title: string;
	activeNav?: "home" | "portafolio" | "services" | "contact";
	description?: string;
	canonical?: string;
	ogImage?: string;
	ogType?: "website" | "article";
	structuredData?: JsonLd | JsonLd[];
}

const {
	title,
	activeNav = "home",
	description = "Web design and development services for professionals, restaurants, and ecommerce brands.",
	canonical,
	ogImage = "/og-image.png",
	ogType = "website",
	structuredData,
} = Astro.props;

const resolvedCanonical = canonical ?? Astro.url.href;
const resolvedOgImage = ogImage.startsWith("http")
	? ogImage
	: Astro.site
		? new URL(ogImage, Astro.site).toString()
		: ogImage;

const site = Astro.site ?? Astro.url;
const pageStructuredData = Array.isArray(structuredData)
	? structuredData
	: structuredData
		? [structuredData]
		: [];
const jsonLd = [organizationSchema(site), ...pageStructuredData];
const serializeJsonLd = (data: JsonLd) =>
	JSON.stringify(data).replace(/</g, "\\u003c");

---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/manifest.json" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="robots" content="index, follow" />
		<meta name="author" content="LUFEP" />
		<meta name="theme-color" content="#1E3A8A" />
		<link rel="canonical" href={resolvedCanonical} />
		<meta property="og:type" content={ogType} />
		<meta property="og:locale" content="es_ES" />
		<meta property="og:site_name" content="LUFEP" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={resolvedCanonical} />
		<meta property="og:image" content={resolvedOgImage} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={resolvedOgImage} />
		<title>{title}</title>
		{jsonLd.map((schema) => <script type="application/ld+json" set:html={serializeJsonLd(schema)} />)}
	</head>
	<body class="bg-[#FAF7F2] text-[#1C1917] antialiased">
		<div class="min-h-screen">
			<Header activeNav={activeNav} />

			<slot />

			<Footer />
		</div>
	</body>
</html>
