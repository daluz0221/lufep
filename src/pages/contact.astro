---
import Layout from "../layouts/layout.astro";
import { breadcrumbListSchema } from "../lib/structuredData";

const site = Astro.site ?? Astro.url;
const structuredData = breadcrumbListSchema(site, [
	{ name: "Inicio", path: "/" },
	{ name: "Contacto", path: "/contact" },
]);
---

<Layout
	title="LUFEP | Contacto"
	activeNav="contact"
	description="Contacta a LUFEP para iniciar tu próximo proyecto de sitio web. Comparte tus objetivos y recibe una propuesta en 24 horas hábiles."
	structuredData={structuredData}
>
	<main>
		<section class="mx-auto w-full max-w-6xl px-6 py-14">
			<p class="text-sm font-semibold uppercase tracking-[0.16em] text-[#1E3A8A]">Connect with us</p>
			<h1 class="mt-4 text-[56px] font-semibold leading-[1.08] text-[#1C1917]">Let's start your project</h1>
			<p class="mt-5 max-w-2xl text-base leading-7 text-[#78716C]">
				Whether you're looking to build a new digital experience or scale your existing platform,
				we're ready to provide the technical expertise you need.
			</p>

			<div class="mt-10 grid gap-6 md:grid-cols-5 md:items-start">
				<div class="rounded-md border border-[#E7E5E4] bg-white p-6 md:col-span-3">
					<form class="space-y-5" method="post" action="#">
						<div class="grid gap-4 md:grid-cols-2">
							<div>
								<label class="text-sm font-semibold uppercase tracking-[0.08em] text-[#78716C]" for="name">Name</label>
								<input id="name" name="name" type="text" autocomplete="name" required placeholder="Full name" class="mt-2 w-full rounded-sm border border-[#E7E5E4] px-4 py-3 text-base outline-none focus:border-[#1E3A8A]" />
							</div>
							<div>
								<label class="text-sm font-semibold uppercase tracking-[0.08em] text-[#78716C]" for="email">Email</label>
								<input id="email" name="email" type="email" autocomplete="email" required placeholder="email@business.com" class="mt-2 w-full rounded-sm border border-[#E7E5E4] px-4 py-3 text-base outline-none focus:border-[#1E3A8A]" />
							</div>
						</div>
						<div>
							<label class="text-sm font-semibold uppercase tracking-[0.08em] text-[#78716C]" for="type">Business type</label>
							<select id="type" name="businessType" required class="mt-2 w-full rounded-sm border border-[#E7E5E4] px-4 py-3 text-base text-[#78716C] outline-none focus:border-[#1E3A8A]">
								<option value="" disabled selected>Select your industry</option>
								<option>Legal</option>
								<option>Finance</option>
								<option>Hospitality</option>
								<option>Healthcare</option>
								<option>Retail</option>
							</select>
						</div>
						<div>
							<label class="text-sm font-semibold uppercase tracking-[0.08em] text-[#78716C]" for="message">Message</label>
							<textarea id="message" name="message" rows="5" required placeholder="Tell us about your project requirements..." class="mt-2 w-full rounded-sm border border-[#E7E5E4] px-4 py-3 text-base outline-none focus:border-[#1E3A8A]"></textarea>
						</div>
						<button type="submit" class="rounded-sm bg-[#1E3A8A] px-7 py-3 text-sm font-semibold text-white">Send Message</button>
					</form>
				</div>

				<div class="space-y-6 md:col-span-2">
					<div class="rounded-md border border-[#E7E5E4] bg-white p-6">
						<div class="border-b border-[#E7E5E4] pb-5">
							<h2 class="text-[34px] font-semibold leading-tight text-[#1C1917]">Fast Response</h2>
							<p class="mt-3 text-base leading-7 text-[#78716C]">
								Our team values your time. We guarantee a detailed response within 24 business hours.
							</p>
						</div>
						<div class="pt-5">
							<h2 class="text-[34px] font-semibold leading-tight text-[#1C1917]">Direct Email</h2>
							<p class="mt-3 text-base leading-7 text-[#78716C]">
								For urgent inquiries or tender documents:<br />
								<span class="font-medium text-[#1E3A8A]">hello@devportfolio.tech</span>
							</p>
						</div>
					</div>
					<div
						class="relative h-60 overflow-hidden rounded-md bg-cover bg-center"
						style="background-image:url('https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?auto=format&fit=crop&w=1200&q=80')"
					>
						<div class="absolute bottom-4 left-4 rounded-sm bg-white px-4 py-3 text-sm text-[#1C1917]">
							<p class="text-sm font-semibold uppercase tracking-[0.08em] text-[#78716C]">Our HQ</p>
							<p class="mt-1">Tech District. Suite 602</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		

		<section class="bg-[#2B2D38]">
			<div class="mx-auto w-full max-w-6xl px-6 py-16 text-center text-white">
				<h2 class="text-[52px] font-semibold leading-[1.1]">Ready to transform your digital presence?</h2>
				<p class="mx-auto mt-4 max-w-2xl text-base leading-7 text-white/80">
					Join over 150+ professional firms who have elevated their business through our modern
					development standards.
				</p>
				<a href="/portafolio" class="mt-8 inline-block rounded-sm bg-[#E07856] px-10 py-3 text-sm font-semibold text-white">View Our Portfolio</a>
			</div>
		</section>
	</main>
</Layout>
